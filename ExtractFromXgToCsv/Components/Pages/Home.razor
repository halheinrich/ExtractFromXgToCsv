@using ConvertXgToJson_Lib.Models
@page "/"
@rendermode InteractiveServer
@inject XgProcessingService Processor
@inject IJSRuntime JS

<PageTitle>ExtractFromXgToCsv</PageTitle>

<h1>Extract XG Decisions to CSV</h1>

@* ── LOCAL MODE ─────────────────────────────────────────────────────────────── *@
@if (Processor.IsLocalEnvironment)
{
    <section class="mb-4">
        <div style="max-width:800px">
            <label class="form-label">Input Folder</label>
            <input class="form-control mb-2" placeholder="e.g. C:\XG\Matches"
                   value="@_folderPath"
                   @oninput="OnInputFolderChanged" />

            <label class="form-label">Output Folder</label>
            <input class="form-control mb-2" placeholder="Defaults to input folder"
                   value="@_outputFolder"
                   @oninput="OnOutputFolderChanged" />

            <label class="form-label">CSV Filename</label>
            <input class="form-control mb-3" placeholder="decisions.csv"
                   value="@_csvFileName"
                   @oninput="OnCsvFileNameChanged" />

            <button class="btn btn-primary" @onclick="ProcessFolderAsync"
                    disabled="@_busy">
                @(_busy ? "Processing…" : "Extract decisions")
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_localOutputPath))
        {
            <div class="alert alert-success mt-3">
                CSV written to: <code>@_localOutputPath</code>
                &nbsp;(@_rows.Count rows)
            </div>
        }
    </section>
}

@* ── AZURE / BROWSER MODE ────────────────────────────────────────────────────── *@
@if (!Processor.IsLocalEnvironment)
{
    <section class="mb-4">
        <h4>Upload .xg / .xgp Files</h4>
        <InputFile OnChange="HandleFileUploadAsync" multiple
                   accept=".xg,.xgp" class="form-control mb-2" style="max-width:500px" />
    </section>
}

@* ── ERROR ───────────────────────────────────────────────────────────────────── *@
@if (_hasError && !string.IsNullOrEmpty(_statusMessage))
{
    <div class="alert alert-danger mt-2">@_statusMessage</div>
}

@* ── PREVIEW ─────────────────────────────────────────────────────────────────── *@
@if (_rows.Count > 0)
{
    <h5>Preview (first 20 of @_rows.Count rows)</h5>
    <div style="overflow-x:auto">
        <table class="table table-sm table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Xgid</th>
                    <th>Error</th>
                    <th>MatchScore</th>
                    <th>MatchLength</th>
                    <th>Player</th>
                    <th>Match</th>
                    <th>Game</th>
                    <th>MoveNum</th>
                    <th>Roll</th>
                    <th>AnalysisDepth</th>
                    <th>Equity</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _rows.Take(20))
                {
                    <tr>
                        <td><code style="font-size:.75em">@r.Xgid</code></td>
                        <td>@r.Error</td>
                        <td>@r.MatchScore</td>
                        <td>@r.MatchLength</td>
                        <td>@r.Player</td>
                        <td>@r.Match</td>
                        <td>@r.Game</td>
                        <td>@r.MoveNum</td>
                        <td>@r.Roll</td>
                        <td>@r.AnalysisDepth</td>
                        <td>@r.Equity</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private string _folderPath = string.Empty;
    private string _outputFolder = string.Empty;
    private string _csvFileName = "decisions.csv";
    private string _statusMessage = string.Empty;
    private string _localOutputPath = string.Empty;
    private bool _busy = false;
    private bool _hasError = false;
    private List<DecisionRow> _rows = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _folderPath = await JS.InvokeAsync<string>("localStorage.getItem", "xg_inputFolder") ?? string.Empty;
            _outputFolder = await JS.InvokeAsync<string>("localStorage.getItem", "xg_outputFolder") ?? string.Empty;
            _csvFileName = await JS.InvokeAsync<string>("localStorage.getItem", "xg_csvFileName") ?? "decisions.csv";
            StateHasChanged();
        }
    }

    private async Task SavePrefsAsync()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_inputFolder", _folderPath);
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_outputFolder", _outputFolder);
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_csvFileName", _csvFileName);
    }

    private async Task OnInputFolderChanged(ChangeEventArgs e)
    {
        _folderPath = e.Value?.ToString() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(_outputFolder))
            _outputFolder = _folderPath;
        await SavePrefsAsync();
    }

    private async Task OnOutputFolderChanged(ChangeEventArgs e)
    {
        _outputFolder = e.Value?.ToString() ?? string.Empty;
        await SavePrefsAsync();
    }

    private async Task OnCsvFileNameChanged(ChangeEventArgs e)
    {
        _csvFileName = e.Value?.ToString() ?? string.Empty;
        await SavePrefsAsync();
    }

    // ── LOCAL: process every .xg/.xgp in the chosen folder ───────────────────
    private async Task ProcessFolderAsync()
    {
        if (string.IsNullOrWhiteSpace(_folderPath)) return;

        _busy = true; _hasError = false; _statusMessage = string.Empty;
        _rows.Clear(); _localOutputPath = string.Empty;

        try
        {
            var files = Processor.GetXgFilesInFolder(_folderPath);
            StateHasChanged();

            foreach (var path in files)
            {
                var bytes = await File.ReadAllBytesAsync(path);
                _rows.AddRange(Processor.ExtractDecisions(bytes, Path.GetFileName(path)));
            }

            var csv = Processor.BuildCsv(_rows);
            var outDir = string.IsNullOrWhiteSpace(_outputFolder) ? _folderPath : _outputFolder;
            var outName = string.IsNullOrWhiteSpace(_csvFileName) ? "decisions.csv" : _csvFileName;
            var outFile = Path.Combine(outDir, outName);

            await Processor.WriteLocalCsvAsync(outFile, csv);
            _localOutputPath = outFile;
        }
        catch (Exception ex)
        {
            _hasError = true;
            _statusMessage = $"Error: {ex.Message}";
        }
        finally { _busy = false; }
    }

    // ── AZURE / BROWSER: handle uploaded files ────────────────────────────────
    private async Task HandleFileUploadAsync(InputFileChangeEventArgs e)
    {
        _hasError = false; _statusMessage = string.Empty;
        _rows.Clear();

        try
        {
            foreach (var file in e.GetMultipleFiles(50))
            {
                using var ms = new MemoryStream();
                await file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
                _rows.AddRange(Processor.ExtractDecisions(ms.ToArray(), file.Name));
            }
        }
        catch (Exception ex)
        {
            _hasError = true;
            _statusMessage = $"Error: {ex.Message}";
        }
    }
}