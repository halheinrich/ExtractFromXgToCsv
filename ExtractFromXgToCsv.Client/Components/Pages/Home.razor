@using BgDataTypes_Lib
@using XgFilter_Lib.Filtering
@using ExtractFromXgToCsv.Client.Shared
@page "/"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject IJSRuntime JS
@inject HttpClient Http
@implements IDisposable

<PageTitle>ExtractFromXgToCsv</PageTitle>

<h1>Extract XG Decisions to CSV</h1>

<div class="mb-3" style="max-width:800px">
    <label class="form-label d-block">Output format</label>
    <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" name="outputFormat" id="fmtCsv"
               checked="@(_outputFormat == OutputFormat.Csv)"
               @onchange="@(() => SetOutputFormat(OutputFormat.Csv))" />
        <label class="form-check-label" for="fmtCsv">CSV</label>
    </div>
    <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" name="outputFormat" id="fmtDiagram"
               checked="@(_outputFormat == OutputFormat.DiagramJson)"
               @onchange="@(() => SetOutputFormat(OutputFormat.DiagramJson))" />
        <label class="form-check-label" for="fmtDiagram">Diagram JSON</label>
    </div>
</div>

<FilterPanel OnFiltersChanged="OnFiltersChanged"
             OnFilterConfigChanged="OnFilterConfigChanged"
             OnFilterDirty="OnFilterDirty" />

@if (_appMode == "Local")
{
    <LocalModePanel OutputFormat="_outputFormat"
                    FilterConfig="_filterConfig"
                    FilterApplied="_filterApplied"
                    FilterDirty="_filterDirty" />
}
else
{
    <WebModePanel OutputFormat="_outputFormat"
                  FilterSet="_filterSet"
                  FilterApplied="_filterApplied"
                  FilterDirty="_filterDirty" />
}

@code {
    private string _appMode = "Web";
    private OutputFormat _outputFormat = OutputFormat.Csv;
    private bool _filterApplied = false;
    private bool _filterDirty = false;
    private DecisionFilterSet _filterSet = new();
    private FilterConfig _filterConfig = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var savedFormat = await JS.InvokeAsync<string?>("localStorage.getItem", "xg_outputFormat");
        if (Enum.TryParse<OutputFormat>(savedFormat, out var fmt))
            _outputFormat = fmt;

        try
        {
            var serverMode = await Http.GetStringAsync("/api/appmode");
            _appMode = serverMode.Trim('"');
        }
        catch { _appMode = "Web"; }

        StateHasChanged();
    }

    public void Dispose() { }

    private void OnFiltersChanged(DecisionFilterSet fs)
    {
        _filterSet = fs;
        _filterApplied = true;
        _filterDirty = false;
        StateHasChanged();
    }

    private void OnFilterConfigChanged(FilterConfig fc)
    {
        _filterConfig = fc;
    }

    private void OnFilterDirty()
    {
        _filterDirty = true;
        StateHasChanged();
    }

    private async Task SetOutputFormat(OutputFormat fmt)
    {
        _outputFormat = fmt;
        await JS.InvokeVoidAsync("localStorage.setItem", "xg_outputFormat", fmt.ToString());
        StateHasChanged();
    }
}